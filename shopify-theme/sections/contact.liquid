<section id="contact" class="section contact">
  <div class="grid-bg"></div>
  <div class="container-x contact-grid">
    <div>
      <div class="eyebrow"><span class="dot"></span> Get started</div>
      <h2 class="contact-title">Got a sign in mind? <span class="text-primary">Let's build it.</span></h2>
      <p class="contact-sub">Drop by the shop, give us a call, or send a message. Free quotes — always.</p>
      <div class="contact-lines">
        <a href="{{ settings.phone_href }}" class="contact-line">
          <p class="lbl">Call</p><p class="val">{{ settings.phone }}</p>
        </a>
        <a href="https://maps.google.com/?q={{ settings.address | url_encode }}" target="_blank" rel="noopener" class="contact-line">
          <p class="lbl">Visit</p><p class="val">{{ settings.address }}</p>
        </a>
        <div class="contact-line">
          <p class="lbl">Hours</p><p class="val">Mon–Fri · 9 AM – 5 PM</p>
        </div>
      </div>
    </div>

    {%- form 'contact', class: 'quote-form' -%}
      <h3>Request a quote</h3>
      {%- if form.posted_successfully? -%}
        <p class="success">Thanks — we'll be in touch shortly.</p>
      {%- endif -%}
      <label>Your name<input type="text" name="contact[name]" required></label>
      <label>Phone<input type="tel" name="contact[phone]" required></label>
      <label>Email<input type="email" name="contact[email]" required></label>
      <label>Project type<input type="text" name="contact[project]" placeholder="e.g. vehicle wrap"></label>
      <label>Project details<textarea name="contact[body]" rows="4" required></textarea></label>
      <button type="submit" class="btn-primary">Send request →</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{ "name": "Contact", "settings": [], "presets": [{ "name": "Contact" }] }
{% endschema %}
