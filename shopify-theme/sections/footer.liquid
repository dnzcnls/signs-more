<footer class="site-footer">
  <div class="container-x footer-inner">
    <div class="brand">
      <span class="brand-dot" aria-hidden="true"></span>
      <span class="brand-text">SIGNS'N MORE LTD</span>
    </div>
    <p class="footer-meta">© {{ 'now' | date: '%Y' }} Signs 'N More Ltd · Lloydminster, SK · {{ settings.phone }}</p>
    {%- if settings.instagram != blank -%}
      <a href="{{ settings.instagram }}" target="_blank" rel="noopener" class="footer-link">Instagram ↗</a>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{ "name": "Footer", "settings": [] }
{% endschema %}
