<section id="work" class="section">
  <div class="container-x">
    {% render 'section-head', eyebrow: 'Recent work', title: section.settings.heading %}
    <div class="gallery-grid">
      {%- assign gallery_fallbacks = 'hero-wrap.jpg,work-storefront.jpg,work-banner.jpg' | split: ',' -%}
      {%- for block in section.blocks -%}
        {%- assign g_idx = forloop.index0 | modulo: 3 -%}
        <figure class="gallery-item {% if forloop.first %}span-2{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 1400 }}" alt="{{ block.settings.caption | escape }}" loading="lazy">
          {%- else -%}
            <img src="{{ gallery_fallbacks[g_idx] | asset_url }}" alt="{{ block.settings.caption | escape }}" loading="lazy">
          {%- endif -%}
          <figcaption><span>{{ block.settings.caption }}</span><span class="text-primary">↗</span></figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gallery",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Out on the road. Up on the wall." }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption" }
      ]
    }
  ],
  "presets": [{
    "name": "Gallery",
    "blocks": [
      { "type": "item", "settings": { "caption": "Fleet wrap · pickup" } },
      { "type": "item", "settings": { "caption": "Channel letter storefront" } },
      { "type": "item", "settings": { "caption": "Event banner" } }
    ]
  }]
}
{% endschema %}
