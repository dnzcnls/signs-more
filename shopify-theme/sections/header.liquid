<header class="site-header" id="top">
  <div class="container-x header-inner">
    <a href="{{ routes.root_url }}" class="brand">
      <span class="brand-dot" aria-hidden="true"></span>
      <span class="brand-text">SIGNS<span class="text-primary">'</span>N MORE</span>
    </a>
    <nav class="main-nav">
      <a href="#services">Services</a>
      <a href="#work">Work</a>
      <a href="#process">Process</a>
      <a href="#reviews">Reviews</a>
      <a href="#contact">Contact</a>
      <a href="{{ routes.cart_url }}">Cart ({{ cart.item_count }})</a>
    </nav>
    <a href="{{ settings.phone_href }}" class="btn-primary btn-sm">
      <span aria-hidden="true">☎</span>
      <span class="hide-sm">{{ settings.phone }}</span>
      <span class="show-sm">Call</span>
    </a>
  </div>
</header>

{% schema %}
{ "name": "Header", "settings": [] }
{% endschema %}
