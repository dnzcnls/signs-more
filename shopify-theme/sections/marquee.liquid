<div class="marquee-wrap">
  <div class="marquee">
    {%- assign items = section.settings.items | split: ',' -%}
    {%- for i in (1..2) -%}
      {%- for t in items -%}
        <span class="marquee-item">{{ t | strip }} <span class="text-primary">✕</span></span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    { "type": "text", "id": "items", "label": "Items (comma separated)",
      "default": "Vehicle Wraps, Channel Letters, Vinyl Banners, Decals, Trade Show Displays, Apparel Print, Magnetic Signs, ACM Panels, Reflective Decals, Window Graphics" }
  ],
  "presets": [{ "name": "Marquee" }]
}
{% endschema %}
