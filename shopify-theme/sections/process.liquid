<section id="process" class="section surface">
  <div class="container-x">
    {% render 'section-head', eyebrow: 'How it works', title: section.settings.heading %}
    <ol class="process-grid">
      {%- for block in section.blocks -%}
        <li {{ block.shopify_attributes }}>
          <p class="num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</p>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.body }}</p>
        </li>
      {%- endfor -%}
    </ol>
  </div>
</section>

{% schema %}
{
  "name": "Process",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Four steps. Zero surprises." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{
    "name": "Process",
    "blocks": [
      { "type": "step", "settings": { "title": "Tell us what you need", "body": "Call, email or stop by the shop. We listen first — then quote fast." } },
      { "type": "step", "settings": { "title": "Design & proof", "body": "Our team mocks it up. You approve every detail before a single inch is printed." } },
      { "type": "step", "settings": { "title": "Print & fabricate", "body": "Production happens on-site with commercial-grade materials made to last." } },
      { "type": "step", "settings": { "title": "Install & stand back", "body": "We install on-vehicle or on-building — clean, level, ready to work for you." } }
    ]
  }]
}
{% endschema %}
