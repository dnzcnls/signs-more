<section id="reviews" class="section">
  <div class="container-x">
    {% render 'section-head', eyebrow: 'What customers say', title: section.settings.heading %}
    <div class="reviews-grid">
      {%- for block in section.blocks -%}
        <blockquote {{ block.shopify_attributes }}>
          <div class="stars">★★★★★</div>
          <p>"{{ block.settings.quote }}"</p>
          <footer>— {{ block.settings.source }}</footer>
        </blockquote>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted across the border city." }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "source", "label": "Source", "default": "Google review" }
      ]
    }
  ],
  "presets": [{
    "name": "Reviews",
    "blocks": [
      { "type": "review", "settings": { "quote": "Amazing place, will definitely do business with them again." } },
      { "type": "review", "settings": { "quote": "Quick and nice quality." } },
      { "type": "review", "settings": { "quote": "They are my go-to sign and promotion shop in town." } }
    ]
  }]
}
{% endschema %}
