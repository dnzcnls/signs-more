<section class="container-x py-20 grid gap-12 md:grid-cols-2">
  <div>
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.featured_image.alt | escape }}" class="border">
    {%- endif -%}
  </div>
  <div>
    <h1 class="text-4xl mb-4">{{ product.title }}</h1>
    <p class="text-primary font-display text-3xl mb-6">{{ product.price | money }}</p>
    <div class="text-muted mb-8">{{ product.description }}</div>
    {% form 'product', product %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <button type="submit" class="btn-primary">Add to cart</button>
    {% endform %}
  </div>
</section>
